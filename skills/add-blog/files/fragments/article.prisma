// ── add-blog: Article model ────────────────────────────────────
// Append this model to the end of prisma/schema.prisma.
// Also add a reverse relation line inside the existing `model User { ... }`:
//     articles      Article[]
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique // Locked after publishing to avoid broken links
  excerpt     String // meta description / list card
  content     String // ProseMirror JSON (JSON.stringify)
  plainText   String // Plain text extracted from content, for search / reading time
  status      String    @default("draft") // "draft" | "published"
  publishedAt DateTime? // Set on first publish, can be edited manually; null for drafts
  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
}
