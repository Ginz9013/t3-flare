# Copy this file to .env and fill in the values. .env is gitignored and not committed.
# When adding a new variable, update the schema in src/env.js at the same time.
#
# ── Each of the three environments loads its own env vars independently; they are not shared ──
#   A. Node local dev (npm run dev)              → reads the .env copied from this file
#   B. Local Workers preview (npm run cf:preview)→ reads .dev.vars + wrangler.jsonc vars
#   C. Production Workers (npm run cf:deploy)     → wrangler.jsonc vars + `wrangler secret put`
#
#   Secrets (BETTER_AUTH_SECRET): locally in .env / .dev.vars; in production use `wrangler secret put`.
#   DATABASE_URL: only Node (A) uses the local SQLite; Workers (B/C) use the D1 binding and don't need it.

# Secret used by Better Auth for password hashing and session signing (generate with `openssl rand -base64 32`)
BETTER_AUTH_SECRET=""
# Public URL (http://localhost:3000 for local dev; https://<name>.workers.dev in production)
BETTER_AUTH_URL="http://localhost:3000"

# Prisma (only for Node local dev / seed; Workers use the D1 binding)
DATABASE_URL="file:./prisma/db.sqlite"

# Initial admin account (used by seed to create the single admin; password must be at least 8 characters)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Admin"
