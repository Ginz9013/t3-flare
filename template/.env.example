# 複製此檔為 .env 並填入值。.env 已 gitignore，不進版控。
# 新增變數時，請同步更新 src/env.js 的 schema。
#
# ── 三個環境各自獨立載入環境變數，不互通 ──────────────────────────
#   A. Node 本機 dev（npm run dev）          → 讀本檔複製出的 .env
#   B. 本機 Workers 預覽（npm run cf:preview）→ 讀 .dev.vars + wrangler.jsonc vars
#   C. 正式 Workers（npm run cf:deploy）      → wrangler.jsonc vars + `wrangler secret put`
#
#   機密（BETTER_AUTH_SECRET）：本機放 .env / .dev.vars；正式用 `wrangler secret put`。
#   DATABASE_URL：僅 Node 端（A）用本機 SQLite；Workers（B/C）走 D1 binding，不需要。

# Better Auth 密碼雜湊與 session 簽章用的 secret（可用 `openssl rand -base64 32` 產生）
BETTER_AUTH_SECRET=""
# 對外網址（本機 dev 用 http://localhost:3000；正式為 https://<name>.workers.dev）
BETTER_AUTH_URL="http://localhost:3000"

# Prisma（僅 Node 本機 dev / seed 用；Workers 走 D1 binding）
DATABASE_URL="file:./prisma/db.sqlite"

# 初始管理員帳號（seed 建立單一管理員用，密碼至少 8 碼）
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Admin"
