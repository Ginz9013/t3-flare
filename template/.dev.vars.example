# Environment variables specifically for local Workers preview (npm run cf:preview / wrangler dev).
# Copy this file to .dev.vars (gitignored). For production secrets, use `wrangler secret put` instead.
#
# Note: the values here "override" the vars in wrangler.jsonc (local dev only).

# Secret for local testing (may match the .env value; must differ from the production secret)
BETTER_AUTH_SECRET=""

# Override with the local preview URL (adjust to the port that cf:preview actually prints)
BETTER_AUTH_URL="http://localhost:8788"
