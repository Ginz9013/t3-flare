{
	"name": "my-site",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"db:generate": "prisma migrate dev",
		"db:migrate": "prisma migrate deploy",
		"db:push": "prisma db push",
		"db:seed": "prisma db seed",
		"db:studio": "prisma studio",
		"dev": "next dev --turbo",
		"cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf:migrate": "wrangler d1 migrations apply my-site --remote",
		"cf:deploy": "wrangler d1 migrations apply my-site --remote && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"cf:typegen": "wrangler types",
		"postinstall": "prisma generate",
		"preview": "next build && next start",
		"start": "next start",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@opennextjs/cloudflare": "^1.19.11",
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/adapter-d1": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@tanstack/react-query": "^5.69.0",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@trpc/server": "^11.0.0",
		"better-auth": "^1.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.21.0",
		"next": "^15.2.3",
		"next-themes": "^0.4.6",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"server-only": "^0.0.1",
		"shadcn": "^4.11.0",
		"sonner": "^2.0.7",
		"superjson": "^2.2.1",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@cloudflare/workers-types": "^4.20250923.0",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"postcss": "^8.5.3",
		"prisma": "^7.8.0",
		"tailwindcss": "^4.0.15",
		"tsx": "^4.22.4",
		"typescript": "^5.8.2",
		"wrangler": "^4.102.0"
	},
	"ct3aMetadata": {
		"initVersion": "7.40.0"
	},
	"packageManager": "npm@10.9.4"
}
